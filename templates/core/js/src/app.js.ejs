import express from 'express';
import cors from 'cors';
import cookieParser from 'cookie-parser';
import routes from './routes/index.js';
<% if (projectType === 'ejs') { %>import viewRoutes from './routes/viewRoutes.js';
import path from 'path';
import { fileURLToPath } from 'url';
const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);<% } %>
<% if (features.includes('logging')) { %>import morgan from 'morgan';<% } %>
<% if (features.includes('docs')) { %>import { specs, swaggerUi } from './config/swagger.js';<% } %>
import { errorHandler, notFound } from './middlewares/errorMiddleware.js';

const app = express();

// Standard Middleware
app.use(cors({
  origin: process.env.CORS_ORIGIN || '*',
  credentials: true
}));

app.use(express.json({ limit: '16kb' }));
app.use(express.urlencoded({ extended: true, limit: '16kb' }));
app.use(cookieParser());
<% if (features.includes('logging')) { %>app.use(morgan('dev'));<% } %>

<% if (projectType === 'ejs') { %>
// EJS Setup
app.set('view engine', 'ejs');
app.set('views', path.join(__dirname, 'views'));
app.use(express.static(path.join(__dirname, 'public')));

// View Routes
app.use('/', viewRoutes);
<% } %>

<% if (features.includes('docs')) { %>
// Swagger Documentation
app.use('/api-docs', swaggerUi.serve, swaggerUi.setup(specs));
<% } %>

// API Routes
app.use('/api/v1', routes);

// 404 & Error Handling
app.use(notFound);
app.use(errorHandler);

export default app;
